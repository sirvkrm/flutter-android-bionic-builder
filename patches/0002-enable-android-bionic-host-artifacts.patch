diff --git a/build/archives/BUILD.gn b/build/archives/BUILD.gn
index 97d9483..fbea421 100644
--- a/build/archives/BUILD.gn
+++ b/build/archives/BUILD.gn
@@ -67,7 +67,11 @@ if (build_engine_artifacts) {
     } else {
       prefix = "$full_target_platform_name/"
     }
-    output = "$prefix/artifacts.zip"
+    output_name = "artifacts.zip"
+    if (is_android && flutter_build_engine_artifacts_for_android) {
+      output_name = "host-artifacts.zip"
+    }
+    output = "$prefix/$output_name"
 
     exe = ""
     if (host_os == "win") {
diff --git a/common/config.gni b/common/config.gni
index b2ae111..f47064b 100644
--- a/common/config.gni
+++ b/common/config.gni
@@ -20,6 +20,10 @@ declare_args() {
   # Whether to build host-side development artifacts.
   flutter_build_engine_artifacts = true
 
+  # Allow explicit opt-in Android builds to emit host-side artifacts (for
+  # example, a Dart SDK that runs under Android bionic in Termux).
+  flutter_build_engine_artifacts_for_android = false
+
   # Whether to include backtrace support.
   enable_backtrace = true
 
@@ -162,7 +166,11 @@ if (flutter_prebuilt_dart_sdk) {
 #
 # TODO: We can't build the engine artifacts for arm (32-bit) right now;
 # see https://github.com/flutter/flutter/issues/74322.
-build_engine_artifacts =
-    flutter_build_engine_artifacts && !is_android &&
-    (current_toolchain == host_toolchain ||
-     (is_linux && !is_chromeos && current_cpu != "arm") || is_mac || is_win)
+build_engine_artifacts = flutter_build_engine_artifacts &&
+                         ((!is_android &&
+                           (current_toolchain == host_toolchain ||
+                            (is_linux && !is_chromeos &&
+                             current_cpu != "arm") || is_mac || is_win)) ||
+                          (is_android &&
+                           flutter_build_engine_artifacts_for_android &&
+                           current_cpu != "arm"))
