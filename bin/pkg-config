#!/usr/bin/env python3
import os
import re
import sys
from pathlib import Path


VAR_RE = re.compile(r"\$\{([^}]+)\}")
VAR_ASSIGN_RE = re.compile(r"^([A-Za-z0-9_]+)\s*=\s*(.*)$")
FIELD_RE = re.compile(r"^([A-Za-z][A-Za-z0-9_.+-]*)\s*:\s*(.*)$")
REQ_NAME_RE = re.compile(r"([A-Za-z0-9_.+-]+)")


class PcPackage:
    def __init__(self, name: str, path: Path) -> None:
        self.name = name
        self.path = path
        self.variables = {}
        self.fields = {}


def expand(value: str, variables: dict[str, str], stack: tuple[str, ...] = ()) -> str:
    def repl(match: re.Match[str]) -> str:
        key = match.group(1)
        if key in stack:
            return ""
        return expand(variables.get(key, ""), variables, stack + (key,))

    previous = None
    current = value
    while previous != current:
        previous = current
        current = VAR_RE.sub(repl, current)
    return current


def parse_pc_file(path: Path, name: str) -> PcPackage:
    package = PcPackage(name, path)
    raw_lines = path.read_text(encoding="utf-8").splitlines()
    lines: list[str] = []
    pending = ""
    for raw in raw_lines:
        line = raw.rstrip()
        if not line or line.lstrip().startswith("#"):
            continue
        if line.endswith("\\"):
            pending += line[:-1]
            continue
        if pending:
            line = pending + line
            pending = ""
        lines.append(line)

    for line in lines:
        var_match = VAR_ASSIGN_RE.match(line)
        if var_match:
            key, value = var_match.groups()
            package.variables[key] = value
            continue
        field_match = FIELD_RE.match(line)
        if field_match:
            key, value = field_match.groups()
            package.fields[key] = value

    package.variables = {
        key: expand(value, package.variables) for key, value in package.variables.items()
    }
    package.fields = {
        key: expand(value, package.variables) for key, value in package.fields.items()
    }
    return package


def parse_package_name(token: str) -> str:
    match = REQ_NAME_RE.search(token.strip())
    return match.group(1) if match else ""


def pc_search_dirs() -> list[Path]:
    search = []
    for env_var in ("PKG_CONFIG_LIBDIR", "PKG_CONFIG_PATH"):
        value = os.environ.get(env_var, "")
        for entry in value.split(":"):
            if entry:
                search.append(Path(entry))
    if not search:
        search.extend(
            [
                Path("/usr/lib/pkgconfig"),
                Path("/usr/share/pkgconfig"),
                Path("/usr/local/lib/pkgconfig"),
                Path("/usr/local/share/pkgconfig"),
            ]
        )
    return search


def load_package(name: str, cache: dict[str, PcPackage]) -> PcPackage:
    if name in cache:
        return cache[name]
    for directory in pc_search_dirs():
        candidate = directory / f"{name}.pc"
        if candidate.is_file():
            cache[name] = parse_pc_file(candidate, name)
            return cache[name]
    raise FileNotFoundError(f"package {name!r} not found in PKG_CONFIG_LIBDIR")


def split_requires(raw: str) -> list[str]:
    if not raw:
        return []
    results = []
    for part in raw.split(","):
        name = parse_package_name(part)
        if name:
            results.append(name)
    return results


def version_key(version: str) -> tuple:
    parts = re.findall(r"\d+|[A-Za-z]+", version)
    key = []
    for part in parts:
        if part.isdigit():
            key.append((0, int(part)))
        else:
            key.append((1, part))
    return tuple(key)


def collect_packages(
    names: list[str], cache: dict[str, PcPackage], include_private: bool = False
) -> list[PcPackage]:
    ordered: list[PcPackage] = []
    seen: set[str] = set()

    def visit(name: str) -> None:
        if name in seen:
            return
        seen.add(name)
        package = load_package(name, cache)
        requires = split_requires(package.fields.get("Requires", ""))
        if include_private:
            requires += split_requires(package.fields.get("Requires.private", ""))
        for dep in requires:
            visit(dep)
        ordered.append(package)

    for name in names:
        visit(name)
    return ordered


def shell_split_flags(value: str) -> list[str]:
    if not value:
        return []
    return [flag for flag in value.split() if flag]


def unique(sequence: list[str]) -> list[str]:
    seen: set[str] = set()
    out = []
    for item in sequence:
        if item in seen:
            continue
        seen.add(item)
        out.append(item)
    return out


def main() -> int:
    args = sys.argv[1:]
    if not args:
        return 1

    variable_name = None
    ask_modversion = False
    cflags = False
    libs = False
    atleast_version = None
    package_names: list[str] = []

    i = 0
    while i < len(args):
        arg = args[i]
        if arg == "--cflags":
            cflags = True
        elif arg == "--libs":
            libs = True
        elif arg == "--modversion":
            ask_modversion = True
        elif arg.startswith("--variable="):
            variable_name = arg.split("=", 1)[1]
        elif arg.startswith("--atleast-version="):
            atleast_version = arg.split("=", 1)[1]
        elif arg.startswith("-"):
            pass
        else:
            name = parse_package_name(arg)
            if name:
                package_names.append(name)
        i += 1

    if not package_names:
        return 1

    cache: dict[str, PcPackage] = {}
    try:
        packages = collect_packages(package_names, cache, include_private=libs)
    except FileNotFoundError as exc:
        sys.stderr.write(f"{exc}\n")
        return 1

    primary = load_package(package_names[0], cache)

    if atleast_version is not None:
        current = primary.fields.get("Version", "")
        ok = version_key(current) >= version_key(atleast_version)
        return 0 if ok else 1

    if variable_name is not None:
        sys.stdout.write(primary.variables.get(variable_name, ""))
        return 0

    if ask_modversion:
        sys.stdout.write(primary.fields.get("Version", ""))
        return 0

    flags: list[str] = []
    if cflags:
        for package in packages:
            flags.extend(shell_split_flags(package.fields.get("Cflags", "")))
    if libs:
        for package in packages:
            flags.extend(shell_split_flags(package.fields.get("Libs", "")))

    sys.stdout.write(" ".join(unique(flags)))
    return 0


if __name__ == "__main__":
    sys.exit(main())
